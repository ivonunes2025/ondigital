---
import Layout from "../layouts/Layout.astro";
---

<Layout title="ON DIGITAL — Websites & Social Media">
  <div class="bg-glow"></div>

  <nav>
    <a href="#" class="nav-logo">ON<span>DIGITAL</span></a>
    <ul class="nav-links">
      <li><a href="#servicos">Serviços</a></li>
      <li><a href="#processo">Processo</a></li>
      <li><a href="#precos">Preços</a></li>
      <li><a href="#contacto">Contacto</a></li>
      <li>
        <a href="/simulador" style="color: var(--gold); font-weight: 600;"
          >Simulador</a
        >
      </li>
    </ul>
    <a href="#contacto" class="nav-cta">Começar Projeto</a>
  </nav>

  <section class="hero">
    <div class="hero-bg-lines"></div>
    <div class="hero-orb"></div>
    <div class="hero-visual">
      <img
        src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=2426"
        alt="Estratégia Digital"
      />
    </div>
    <div class="hero-content">
      <div class="hero-tag">Agência Digital</div>
      <h1 class="hero-title">
        <span class="line">DESIGN QUE</span>
        <span class="line">CONECTA <span class="hero-amp">&</span></span>
        <span class="line">CONVERTE.</span>
      </h1>
      <p class="hero-sub">
        Criamos experiências digitais que elevam a tua marca e impulsionam
        resultados através de design estratégico e tecnologia de ponta.
      </p>
      <div class="hero-actions">
        <a href="#servicos" class="btn-primary">
          <span>Ver Serviços</span>
          <svg
            class="arrow"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
          >
            <path
              d="M1 8H15M15 8L8 1M15 8L8 15"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
        <a href="#processo" class="btn-ghost">Como Trabalhamos</a>
      </div>
    </div>
    <div class="hero-scroll-indicator">Scroll</div>
  </section>

  <section id="servicos">
    <div class="services-header">
      <h2 class="services-title">Soluções <em>Digitais</em><br />À Medida</h2>
      <p class="services-desc">
        Proporcionamos um ecossistema completo para a sua presença digital,
        aliando uma estética requintada a uma funcionalidade irrepreensível.
      </p>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-number">01</div>
        <div class="service-icon">
          <svg viewBox="0 0 24 24">
            <path d="M2 3h20v14H2zM2 17h20v4H2z"></path>
          </svg>
        </div>
        <h3 class="service-name">Desenvolvimento Web</h3>
        <p class="service-text">
          Websites rápidos, seguros e otimizados para converter visitantes em
          clientes fiéis.
        </p>
        <a href="#" class="service-link">Saber Mais</a>
      </div>
      <div class="service-card">
        <div class="service-number">02</div>
        <div class="service-icon">
          <svg viewBox="0 0 24 24">
            <path d="M12 2l10 10-10 10-10-10z"></path>
          </svg>
        </div>
        <h3 class="service-name">Redes Sociais</h3>
        <p class="service-text">
          Estratégias de conteúdo que humanizam a sua marca e criam comunidades
          envolvidas.
        </p>
        <a href="#" class="service-link">Saber Mais</a>
      </div>
      <div class="service-card">
        <div class="service-number">03</div>
        <div class="service-icon">
          <svg viewBox="0 0 24 24">
            <path d="M4 4h16v16H4zM9 9h6v6H9z"></path>
          </svg>
        </div>
        <h3 class="service-name">Design UI/UX</h3>
        <p class="service-text">
          Interfaces intuitivas focadas na experiência do utilizador e na
          identidade da marca.
        </p>
        <a href="#" class="service-link">Saber Mais</a>
      </div>
    </div>
  </section>

  <section class="image-break">
    <div class="break-content">
      <img
        src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=2071"
        alt="Colaboração ON DIGITAL"
      />
      <div class="break-overlay">
        <h2 class="break-text">Do Invisível ao Inesquecível — A Sua Marca, Reinventada.</h2>
      </div>
    </div>
  </section>

  <section id="processo">
    <div class="process-inner">
      <div class="process-sticky">
        <div class="section-label"><span class="num">02</span> Metodologia</div>
        <h2 class="process-title">O Caminho para o<br />Sucesso Digital</h2>
        <p class="process-sub">
          Um processo estruturado para garantir que cada detalhe do seu projeto
          seja executado com perfeição.
        </p>
        <div class="process-visual-mini">
          <img
            src="https://images.unsplash.com/photo-1558655146-d09347e92766?auto=format&fit=crop&q=80&w=1964"
            alt="Design Process"
          />
        </div>
      </div>
      <div class="process-steps">
        <div class="step">
          <div class="step-num">01</div>
          <div class="step-content">
            <h3 class="step-title">Descoberta</h3>
            <p class="step-text">
              Analisamos o seu mercado, objetivos e público-alvo para traçar a
              melhor estratégia.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div class="step-content">
            <h3 class="step-title">Estratégia & Design</h3>
            <p class="step-text">
              Criamos protótipos e conceitos visuais que alinham a sua visão com
              as melhores práticas de UX.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div class="step-content">
            <h3 class="step-title">Desenvolvimento</h3>
            <p class="step-text">
              Transformamos o design em código limpo, rápido e responsivo
              utilizando tecnologias modernas.
            </p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">04</div>
          <div class="step-content">
            <h3 class="step-title">Lançamento & Suporte</h3>
            <p class="step-text">
              Acompanhamos o lançamento e oferecemos suporte contínuo para
              garantir o crescimento.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="strapi">
    <div class="strapi-inner">
      <div class="strapi-visual">
        <img
          src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&q=80&w=2072"
          alt="Interface CMS"
        />
        <div class="strapi-overlay">
          <div
            class="floating-badge"
            style="position: relative; animation: none; margin-bottom: 20px; width: fit-content;"
          >
            <div class="badge-dot"></div>Controlo Total
          </div>
          <div
            class="floating-badge"
            style="position: relative; animation: none; width: fit-content;"
          >
            <div class="badge-dot green"></div>Atualizações em Tempo Real
          </div>
        </div>
      </div>
      <div class="strapi-text">
        <div class="section-label">
          <span class="num">03</span> Gestão de Conteúdo
        </div>
        <h2 class="strapi-title">
          Autonomia Total com <span>Strapi CMS</span>
        </h2>
        <p class="strapi-body">
          Integramos o Strapi, o CMS headless líder de mercado, para que possa
          gerir todo o conteúdo do seu website de forma intuitiva, sem tocar
          numa linha de código.
        </p>
        <div class="strapi-features">
          <div class="strapi-feature">
            <div class="strapi-feature-icon">
              <svg viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <div>
              <h3 class="strapi-feature-title">Segurança Máxima</h3>
              <p class="strapi-feature-text">
                Arquitetura moderna e robusta para proteger os seus dados.
              </p>
            </div>
          </div>
          <div class="strapi-feature">
            <div class="strapi-feature-icon">
              <svg viewBox="0 0 24 24">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
              </svg>
            </div>
            <div>
              <h3 class="strapi-feature-title">Performance Superior</h3>
              <p class="strapi-feature-text">
                Entrega de conteúdo via API para carregamentos ultra-rápidos.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="precos">
    <div class="pricing-header">
      <div class="section-label" style="justify-content: center;">
        <span class="num">04</span> Investimento
      </div>
      <h2 class="pricing-title">Planos Transparentes</h2>
    </div>
    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-tier">Starter</div>
        <div class="price-amount"><sup>€</sup>299.99</div>
        <div class="price-period">Pagamento único para Landing Page</div>
        <div class="price-divider"></div>
        <ul class="price-features">
          <li>Landing Page Personalizada</li>
          <li>Design Responsivo</li>
          <li>Otimização SEO Básica</li>
          <li class="muted">Gestão Strapi CMS</li>
          <li class="muted">Suporte Mensal</li>
        </ul>
        <a href="#" class="price-btn">Escolher Starter</a>
      </div>
      <div class="price-card featured">
        <div class="price-badge">Mais Popular</div>
        <div class="price-tier">Professional</div>
        <div class="price-amount"><sup>€</sup>699.99</div>
        <div class="price-period">Ideal para Empresas em Crescimento</div>
        <div class="price-divider"></div>
        <ul class="price-features">
          <li>Website Multi-página</li>
          <li>Integração Strapi CMS</li>
          <li>Blog & Área de Notícias</li>
          <li>Otimização de Velocidade</li>
          <li>Suporte por 3 meses</li>
        </ul>
        <a href="#" class="price-btn">Escolher Professional</a>
      </div>
      <div class="price-card">
        <div class="price-tier">Social Elite</div>
        <div class="price-amount"><sup>€</sup>249.99</div>
        <div class="price-period">Por mês - Gestão Completa</div>
        <div class="price-divider"></div>
        <ul class="price-features">
          <li>12 Posts Mensais</li>
          <li>Gestão de Comunidade</li>
          <li>Relatório de Performance</li>
          <li>Copywriting Estratégico</li>
          <li>Design de Criativos</li>
        </ul>
        <a href="#" class="price-btn">Escolher Social</a>
      </div>
    </div>
  </section>

  <section id="contacto">
    <div class="cta-lines"></div>
    <div class="cta-inner">
      <span class="cta-pre">Vamos falar sobre o seu próximo projeto?</span>
      <h2 class="cta-title">PRONTO PARA <span>BRILHAR?</span></h2>
      <p class="cta-body">
        Estamos prontos para levar a sua marca ao próximo nível. Envie-nos uma
        mensagem e responderemos em menos de 24 horas.
      </p>
      <a href="mailto:ondigitalx@gmail.com" class="cta-email"
        >ondigitalx@gmail.com</a
      >
      <div class="cta-divider"></div>
      <div
        class="hero-actions"
        style="justify-content: center; flex-direction: column; gap: 20px;"
      >
        <a
          href="https://wa.me/351911105998"
          target="_blank"
          class="btn-primary"
        >
          <span>WhatsApp Business</span>
          <svg
            class="arrow"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-10.6 8.38 8.38 0 0 1 3.8.9L21 3.5Z"
            ></path>
          </svg>
        </a>
        <a href="#" class="btn-ghost">Marcar Reunião Gratuita</a>
      </div>
    </div>
  </section>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="#" class="footer-logo">ON<span>DIGITAL</span></a>
        <p class="footer-tagline">
          A elevar marcas através de design excecional e tecnologia inovadora.
        </p>
      </div>
      <div>
        <h4 class="footer-link-title">Navegação</h4>
        <ul class="footer-links">
          <li><a href="#servicos">Serviços</a></li>
          <li><a href="#processo">Processo</a></li>
          <li><a href="#strapi">Strapi CMS</a></li>
          <li><a href="#precos">Preços</a></li>
          <li><a href="/simulador">Simulador</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer-link-title">Contacto</h4>
        <ul class="footer-links">
          <li>
            <a href="mailto:ondigitalx@gmail.com">ondigitalx@gmail.com</a>
          </li>
          <li><a href="tel:+351911105998">+351 911 105 998</a></li>
          <li>
            <a href="https://wa.me/351911105998" target="_blank">WhatsApp</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="footer-link-title">Social</h4>
        <ul class="footer-links">
          <li>
            <a href="https://www.instagram.com/on_digitalx/" target="_blank"
              >Instagram</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 ON DIGITAL. Todos os direitos reservados.</p>
      <p>Feito com &hearts; em Portugal</p>
    </div>
  </footer>
</Layout>
